# ===== 声形绘后端环境变量 =====
# 复制为 .env 并填入实际值

# 服务端口
PORT=8787

# PostgreSQL 数据库连接串（文档第 11 节：Supabase 或本地 PG）
# Supabase 示例: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# 本地 PG 示例: postgresql://postgres:postgres@localhost:5432/soundshape
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soundshape

# JWT 密钥（生产环境务必改成随机长字符串，至少 32 位）
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars-please

# JWT Token 有效期（如 7d / 12h / 30m）
JWT_EXPIRES_IN=7d

# CORS 允许的前端来源（* 表示全部）
CORS_ORIGIN=*
